# Patha — environment variables (copy to .env, never commit the real .env)
#
# .env is in .gitignore. You can also export these in your shell.

# ─── Frontier-LLM Articulation Bridge runs ──────────────────────────
#
# Set this to run the Articulation Bridge eval against Claude Sonnet 4
# (or any anthropic model). Used by `eval/run_answer_eval.py --llm claude`.
#
# Get a key at: https://console.anthropic.com/settings/keys
# Estimated cost for a full KU 78q run with claude-sonnet-4: ~$0.50–$2.

ANTHROPIC_API_KEY=

# Optional — pin the Claude model. Defaults to claude-sonnet-4-20250514.
# CLAUDE_MODEL=claude-sonnet-4-20250514

# ─── Local Ollama (no key needed; just point at the running daemon) ──
#
# Used by `eval/run_answer_eval.py --llm ollama`. Default host below
# is what `ollama serve` listens on locally.

# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:14b-instruct

# ─── Patha runtime knobs (not eval-specific) ─────────────────────────

# PATHA_PHASE1=on              # Retrieval Layer in MCP server (default: on)
# PATHA_GANITA=on              # Ganita synthesis index (default: on)
# PATHA_HEBBIAN=on             # Hebbian co-retrieval expansion (default: on)
# PATHA_STORE_PATH=~/.patha    # Where the JSONL belief store lives
# PATHA_KARANA=regex           # Karana extractor variant: regex|ollama|hybrid
